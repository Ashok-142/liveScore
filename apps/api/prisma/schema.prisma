generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MatchStatus {
  SCHEDULED
  LIVE
  COMPLETED
}

enum TossDecision {
  BAT
  BOWL
}

enum ExtraType {
  NONE
  WIDE
  NO_BALL
  BYE
  LEG_BYE
}

enum WicketType {
  BOWLED
  CAUGHT
  LBW
  RUN_OUT
  STUMPED
  HIT_WICKET
  NONE
}

model Team {
  id                String           @id @default(cuid())
  name              String
  shortCode         String           @unique
  adminUserId       String?
  createdAt         DateTime         @default(now())
  adminUser         User?            @relation("TeamAdmin", fields: [adminUserId], references: [id], onDelete: SetNull)
  players           Player[]
  homeMatches       Match[]          @relation("HomeTeam")
  awayMatches       Match[]          @relation("AwayTeam")
  tossWonMatches    Match[]          @relation("TossWinner")
  firstBatMatches   Match[]          @relation("FirstBattingTeam")
  firstBowlMatches  Match[]          @relation("FirstBowlingTeam")
  battingInnings    Innings[]        @relation("BattingTeam")
  bowlingInnings    Innings[]        @relation("BowlingTeam")
  teamCareerStat    TeamCareerStat?
  playerMatchStat   PlayerMatchStat[]
  playingXIEntries  MatchPlayingXI[]
  tournamentEntries TournamentTeam[]

  @@index([adminUserId])
}

model Tournament {
  id              String           @id @default(cuid())
  name            String
  createdByUserId String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdBy       User             @relation("TournamentCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  teams           TournamentTeam[]

  @@index([createdByUserId])
  @@index([createdAt])
}

model TournamentTeam {
  id           String     @id @default(cuid())
  tournamentId String
  teamId       String
  createdAt    DateTime   @default(now())
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, teamId])
  @@index([teamId])
}

model Player {
  id               String            @id @default(cuid())
  teamId           String
  name             String
  role             String
  createdAt        DateTime          @default(now())
  team             Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  strikerEvents    BallEvent[]       @relation("Striker")
  nonStrikerEvents BallEvent[]       @relation("NonStriker")
  bowlerEvents     BallEvent[]       @relation("Bowler")
  dismissedEvents  BallEvent[]       @relation("DismissedPlayer")
  fieldingEvents   BallEvent[]       @relation("Fielder")
  matchStats       PlayerMatchStat[]
  careerStat       PlayerCareerStat?
  playingXIEntries MatchPlayingXI[]

  @@index([teamId])
}

model Match {
  id                 String            @id @default(cuid())
  homeTeamId         String
  awayTeamId         String
  tossWinnerTeamId   String?
  tossDecision       TossDecision?
  firstBattingTeamId String?
  firstBowlingTeamId String?
  status             MatchStatus       @default(SCHEDULED)
  currentInnings     Int               @default(1)
  oversLimit         Int               @default(20)
  startedAt          DateTime?
  completedAt        DateTime?
  winnerTeamId       String?
  homeTeam           Team              @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam           Team              @relation("AwayTeam", fields: [awayTeamId], references: [id])
  tossWinnerTeam     Team?             @relation("TossWinner", fields: [tossWinnerTeamId], references: [id])
  firstBattingTeam   Team?             @relation("FirstBattingTeam", fields: [firstBattingTeamId], references: [id])
  firstBowlingTeam   Team?             @relation("FirstBowlingTeam", fields: [firstBowlingTeamId], references: [id])
  innings            Innings[]
  events             BallEvent[]
  playerStats        PlayerMatchStat[]
  playingXI          MatchPlayingXI[]

  @@index([status])
  @@index([homeTeamId])
  @@index([awayTeamId])
}

model MatchPlayingXI {
  id        String   @id @default(cuid())
  matchId   String
  teamId    String
  playerId  String
  isCaptain Boolean  @default(false)
  isViceCaptain Boolean @default(false)
  createdAt DateTime @default(now())
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
  @@index([matchId, teamId])
}

model Innings {
  id            String      @id @default(cuid())
  matchId       String
  number        Int
  battingTeamId String
  bowlingTeamId String
  runs          Int         @default(0)
  wickets       Int         @default(0)
  balls         Int         @default(0)
  match         Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  battingTeam   Team        @relation("BattingTeam", fields: [battingTeamId], references: [id])
  bowlingTeam   Team        @relation("BowlingTeam", fields: [bowlingTeamId], references: [id])
  events        BallEvent[]

  @@unique([matchId, number])
  @@index([matchId])
}

model BallEvent {
  id            String      @id @default(cuid())
  matchId       String
  inningsId     String
  overNumber    Int
  ballInOver    Int
  strikerId     String
  nonStrikerId  String
  bowlerId      String
  dismissedPlayerId String?
  fielderId     String?
  runsOffBat    Int
  extraType     ExtraType   @default(NONE)
  extraRuns     Int         @default(0)
  isWicket      Boolean     @default(false)
  wicketType    WicketType  @default(NONE)
  commentary    String?
  createdAt     DateTime    @default(now())
  match         Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  innings       Innings     @relation(fields: [inningsId], references: [id], onDelete: Cascade)
  striker       Player      @relation("Striker", fields: [strikerId], references: [id])
  nonStriker    Player      @relation("NonStriker", fields: [nonStrikerId], references: [id])
  bowler        Player      @relation("Bowler", fields: [bowlerId], references: [id])
  dismissedPlayer Player?   @relation("DismissedPlayer", fields: [dismissedPlayerId], references: [id], onDelete: SetNull)
  fielder       Player?     @relation("Fielder", fields: [fielderId], references: [id], onDelete: SetNull)

  @@index([matchId, createdAt])
  @@index([inningsId, overNumber])
  @@index([dismissedPlayerId])
  @@index([fielderId])
}

model PlayerMatchStat {
  id            String   @id @default(cuid())
  matchId       String
  teamId        String
  playerId      String
  runsScored    Int      @default(0)
  ballsFaced    Int      @default(0)
  dismissals    Int      @default(0)
  fours         Int      @default(0)
  sixes         Int      @default(0)
  wicketsTaken  Int      @default(0)
  ballsBowled   Int      @default(0)
  runsConceded  Int      @default(0)
  dotBalls      Int      @default(0)
  catches       Int      @default(0)
  stumpings     Int      @default(0)
  runOuts       Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team          Team     @relation(fields: [teamId], references: [id])
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
  @@index([teamId])
}

model PlayerCareerStat {
  id            String   @id @default(cuid())
  playerId      String   @unique
  runsScored    Int      @default(0)
  ballsFaced    Int      @default(0)
  dismissals    Int      @default(0)
  fours         Int      @default(0)
  sixes         Int      @default(0)
  wicketsTaken  Int      @default(0)
  ballsBowled   Int      @default(0)
  runsConceded  Int      @default(0)
  dotBalls      Int      @default(0)
  catches       Int      @default(0)
  stumpings     Int      @default(0)
  runOuts       Int      @default(0)
  updatedAt     DateTime @updatedAt
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model TeamCareerStat {
  id                String   @id @default(cuid())
  teamId            String   @unique
  matchesPlayed     Int      @default(0)
  wins              Int      @default(0)
  losses            Int      @default(0)
  totalRunsScored   Int      @default(0)
  totalRunsConceded Int      @default(0)
  totalWicketsTaken Int      @default(0)
  totalWicketsLost  Int      @default(0)
  updatedAt         DateTime @updatedAt
  team              Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model User {
  id                 String        @id @default(cuid())
  name               String
  email              String        @unique
  passwordHash       String
  playerId           String        @unique
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  teamsAdministered  Team[]        @relation("TeamAdmin")
  tournamentsCreated Tournament[]  @relation("TournamentCreator")
  authSessions       AuthSession[]
}

model AuthSession {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
